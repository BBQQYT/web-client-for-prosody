# ---- Web server ----
PORT=8080
HOST=0.0.0.0
APP_NAME=XMPP Web

# ---- XMPP / Prosody ----
# WebSocket endpoint exposed by Prosody's mod_websocket.
# If you serve this app behind the same domain via a reverse proxy you can use a
# same-origin path like wss://chat.example.com/xmpp-websocket
XMPP_WS_URL=wss://example.com:5281/xmpp-websocket

# Optional: BOSH endpoint fallback (mod_bosh)
# XMPP_BOSH_URL=https://example.com:5281/http-bind

# Default domain so users can log in with just "alice" instead of alice@example.com
XMPP_DEFAULT_DOMAIN=example.com

# Optional: default MUC (group chat) service
XMPP_MUC_SERVICE=conference.example.com
